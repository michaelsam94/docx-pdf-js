# Copy to ".env" in this folder (do not commit .env).
# The resume script loads .env before USE_AI runs; existing shell variables are not overwritten.

# --- OpenAI (simplest for local AI CV) ---
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o-mini

# --- Anthropic ---
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_MODEL=claude-3-5-haiku-20241022

# --- Cursor Cloud Agents (slower; MUST have a GitHub repo URL if this folder is not `git clone` with GitHub origin) ---
# CURSOR_API_KEY=key_...
# CURSOR_REPOSITORY=https://github.com/your-user/your-repo
# CURSOR_REF=main
#
# If you only use CURSOR_API_KEY, you almost always need CURSOR_REPOSITORY above (Cloud Agents API requirement).
