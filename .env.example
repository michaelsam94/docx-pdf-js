# Copy to ".env" in this folder (do not commit .env).
# The resume script loads .env before USE_AI runs; existing shell variables are not overwritten.

# --- OpenAI (simplest for local AI CV) ---
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o-mini

# --- Anthropic ---
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_MODEL=claude-3-5-haiku-20241022

# Optional: OpenAI-compatible base URL (local proxy, Azure-style gateways, etc.)
# OPENAI_BASE_URL=https://api.openai.com/v1

# --- Gemini (Google AI Studio) ---
# GEMINI_API_KEY=AIza...
# GEMINI_MODEL=gemini-flash-latest
# (e.g. gemini-2.5-flash, gemini-2.0-flash — see ListModels in Gemini API docs)
# Optional override if you use a proxy / different endpoint:
# GEMINI_API_BASE_URL=https://generativelanguage.googleapis.com
#
# ENOTFOUND generativelanguage.googleapis.com = your Mac cannot resolve Google (offline, VPN,
# firewall, or bad DNS). Fix network/DNS; optional check: dig generativelanguage.googleapis.com +short

# If several keys are set, pick one:
# AI_PROVIDER=openai
# AI_PROVIDER=anthropic
# AI_PROVIDER=gemini

# Cursor dashboard keys are not read by this script for LLM calls.

# --- Fixed contact (styled DOCX; overrides resume.txt / USE_AI for contact row + links) ---
# USE_FIXED_CONTACT=1
# CONTACT_PHONE=+201098002198
# CONTACT_PORTFOLIO=https://michaelsam00.netlify.app
# CONTACT_LINKEDIN=https://www.linkedin.com/in/michaelsam00
# CONTACT_GITHUB=https://github.com/michaelsam94
# CONTACT_EMAIL=michaelsam00@yahoo.com

# --- Fixed Featured Project (Play Store link; styled DOCX) ---
# USE_FIXED_FEATURED_PROJECT=1
# FEATURED_PROJECT_URL=https://play.google.com/store/apps/details?id=com.mega.plug
# FEATURED_PROJECT_URL_LABEL=Google Play
# Optional overrides (otherwise title/description come from resume.txt or USE_AI):
# FEATURED_PROJECT_TITLE=MegaPlug — EV Charging Management Platform
# FEATURED_PROJECT_DESCRIPTION=...
